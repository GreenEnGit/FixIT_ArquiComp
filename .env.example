# FixIT ERP v3 - Variables de Entorno
# Copia este archivo como .env y completa con tus valores reales:
#   cp .env.example .env

# Clave secreta para firmar tokens JWT (OBLIGATORIO - genera una clave única)
# Puedes generar una con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=""

# Google Gemini (Para el Chatbot de Inteligencia Artificial)
# Si se deja vacío, el chatbot usará "Modo Simulación" con la base de conocimientos local.
GEMINI_API_KEY=""

# Twilio (Para notificaciones SMS de estados de reparación)
# Si se dejan vacíos, las notificaciones se simularán en la consola.
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""
